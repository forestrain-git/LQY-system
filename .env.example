# 龙泉驿环卫智能体 - 环境变量配置
# LQY Sanitation Intelligence System - Environment Configuration

# ===========================================
# 数据库配置 / Database Configuration
# ===========================================
POSTGRES_USER=lqy_user
POSTGRES_PASSWORD=change_me_secure_password_123
POSTGRES_DB=lqy_db
DATABASE_URL=postgresql+asyncpg://lqy_user:change_me_secure_password_123@db:5432/lqy_db

# ===========================================
# Redis配置 / Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# MQTT配置 / MQTT Configuration
# ===========================================
MQTT_BROKER=emqx
MQTT_PORT=1883
EMQX_COOKIE=emqxsecretcookie

# ===========================================
# 安全配置 / Security Configuration
# ===========================================
# 生成随机密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_random_secret_key_here

# ===========================================
# AI配置 (可选) / AI Configuration (Optional)
# 从 https://platform.moonshot.cn/ 获取API Key
# ===========================================
KIMI_API_KEY=your_kimi_api_key_here

# ===========================================
# 应用配置 / Application Configuration
# ===========================================
LOG_LEVEL=INFO
ENVIRONMENT=production
